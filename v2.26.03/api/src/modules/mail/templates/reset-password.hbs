<html lang='pt-BR'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{subject}}</title>
    <!--[if mso]>
      <noscript>
        <xml>
          <o:OfficeDocumentSettings>
            <o:PixelsPerInch>96</o:PixelsPerInch>
          </o:OfficeDocumentSettings>
        </xml>
      </noscript>
    <![endif]-->
    <style>
      body {
        margin: 0;
        padding: 0;
        width: 100% !important;
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }
      table,
      td {
        border-collapse: collapse;
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      img {
        border: 0;
        height: auto;
        line-height: 100%;
        outline: none;
        text-decoration: none;
        -ms-interpolation-mode: bicubic;
      }
    </style>
  </head>
  <body
    style='
      background-color: #f8fafc;
      font-family:
        -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, Roboto,
        Helvetica, Arial, sans-serif;
      margin: 0;
      padding: 0;
    '
  >
    <table
      width='100%'
      border='0'
      cellspacing='0'
      cellpadding='0'
      bgcolor='#f8fafc'
    >
      <tr>
        <td align='center' style='padding: 40px 20px'>
          <!-- Main Container -->
          <table
            width='100%'
            border='0'
            cellspacing='0'
            cellpadding='0'
            style='
              max-width: 540px;
              background-color: #ffffff;
              border-radius: 24px;
              box-shadow:
                0 4px 6px -1px rgba(0, 0, 0, 0.05),
                0 10px 15px -3px rgba(0, 0, 0, 0.03);
            '
          >
            <!-- Branding Header -->
            <tr>
              <td align='center' style='padding: 48px 40px 32px 40px;'>
                <div
                  style='background-color: #f1f5f9; width: 64px; height: 64px; border-radius: 16px; display: inline-block; text-align: center; line-height: 64px;'
                >
                  <span style='font-size: 32px;'>🔑</span>
                </div>
                <h1
                  style='margin: 24px 0 0 0; font-size: 24px; color: #0f172a; font-weight: 800; letter-spacing: -0.025em; line-height: 32px;'
                >
                  Redefinição de Senha
                </h1>
              </td>
            </tr>

            <!-- Content Body -->
            <tr>
              <td style='padding: 0 48px 32px 48px; text-align: center'>
                <p
                  style='
                    margin: 0 0 16px 0;
                    font-size: 16px;
                    color: #475569;
                    line-height: 24px;
                  '
                >
                  Olá,
                  <strong style='color: #1e293b'>{{nome}}</strong>.
                </p>
                <p
                  style='
                    margin: 0;
                    font-size: 16px;
                    color: #64748b;
                    line-height: 26px;
                  '
                >
                  Você solicitou a alteração da sua senha de acesso. Para
                  garantir a segurança da sua conta, clique no botão abaixo para
                  escolher uma nova credencial.
                </p>
              </td>
            </tr>

            <!-- Primary Action Button -->
            <tr>
              <td align='center' style='padding-bottom: 30px'>
                <a
                  href='{{url}}'
                  target='_blank'
                  style='
                    background: linear-gradient(90deg, #2563eb, #1e40af);
                    color: #ffffff;
                    text-decoration: none;
                    padding: 16px 36px;
                    border-radius: 12px;
                    font-size: 15px;
                    font-weight: 600;
                    display: inline-block;
                    letter-spacing: 0.5px;
                    transition: all 0.2s ease-in-out;
                  '
                  onmouseover="
                    this.style.background =
                      'linear-gradient(90deg,#1E40AF,#2563EB)'
                  "
                  onmouseout="
                    this.style.background =
                      'linear-gradient(90deg,#2563EB,#1E40AF)'
                  "
                >
                  Atualizar minha senha
                </a>
              </td>
            </tr>

            <!-- Fallback link -->
            <tr>
              <td align='center' style='padding: 0 40px 30px 40px'>
              </td>
            </tr>

            <!-- Info/Warning Box -->
            <tr>
              <td style='padding: 0 48px 40px 48px'>
                <div
                  style='
                    background-color: #fff1f2;
                    border-radius: 12px;
                    padding: 16px;
                    text-align: center;
                  '
                >
                  <p
                    style='
                      margin: 0;
                      font-size: 13px;
                      color: #e11d48;
                      font-weight: 500;
                    '
                  >
                    Este link é válido apenas pelos próximos 10 minutos.
                  </p>
                </div>
              </td>
            </tr>

            <!-- Footer Branding -->
            <tr>
              <td align='center' style='padding: 0 48px 48px 48px'>
                <img
                  src='https://github.com/Coreondev.png'
                  alt='Coreon'
                  width='48'
                  style='
                    border-radius: 10px;
                    margin-bottom: 16px;
                    filter: grayscale(100%);
                    opacity: 0.7;
                  '
                />
                <p
                  style='
                    margin: 0;
                    font-size: 12px;
                    color: #94a3b8;
                    line-height: 20px;
                  '
                >
                  Se você não reconhece esta ação, por favor ignore este aviso.<br
                  />
                  Sua conta permanece protegida.
                </p>
                <p
                  style='
                    margin: 24px 0 0 0;
                    font-size: 11px;
                    color: #cbd5e1;
                    font-weight: 500;
                    letter-spacing: 0.02em;
                  '
                >
                  ©
                  {{year}}
                  Coreon &bull; Todos os direitos reservados.
                </p>
              </td>
            </tr>
          </table>
          <!-- End Main Container -->
        </td>
      </tr>
    </table>
  </body>
</html>